{
  "name": "@macrodata/opencode",
  "version": "0.3.0",
  "description": "Stateful agent tools for OpenCode. Learns who you are, remembers what you're working on, schedules tasks, maintains itself.",
  "type": "module",
  "main": "./dist/opencode/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm build",
    "start": "node dist/src/index.js",
    "daemon": "node dist/bin/macrodata-daemon.js",
    "pretest": "pnpm build",
    "test": "vitest run",
    "check": "oxlint --type-aware --type-check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt"
  },
  "keywords": [
    "opencode",
    "claude-code",
    "plugin",
    "memory",
    "agent",
    "autonomous",
    "local",
    "journal",
    "semantic-search"
  ],
  "author": "Matt Kane",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ascorbic/macrodata.git",
    "directory": "plugins/macrodata"
  },
  "homepage": "https://github.com/ascorbic/macrodata#readme",
  "bugs": {
    "url": "https://github.com/ascorbic/macrodata/issues"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.1.0",
    "@opencode-ai/plugin": "^1.0.162",
    "@opencode-ai/sdk": "^1.1.49",
    "chokidar": "^4.0.3",
    "croner": "^9.0.0",
    "vectra": "^0.9.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.0.0",
    "oxlint-tsgolint": "latest",
    "tsdown": "latest"
  },
  "opencode": {
    "type": "plugin",
    "hooks": [
      "chat.message",
      "experimental.session.compacting"
    ]
  },
  "files": [
    "dist",
    "src",
    "opencode",
    "bin",
    "USAGE.md"
  ]
}
