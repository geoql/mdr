{
  "name": "@geoql/mdr",
  "version": "1.0.1",
  "description": "Persistent layered memory for coding agents (OpenCode, Claude Code) — journal, entities, state files, semantic search, daemon, scheduled reminders. A hard fork of ascorbic/macrodata by Matt Kane.",
  "keywords": [
    "agent",
    "autonomous",
    "claude-code",
    "journal",
    "local",
    "memory",
    "opencode",
    "plugin",
    "semantic-search"
  ],
  "homepage": "https://mdr.geoql.in",
  "bugs": {
    "url": "https://github.com/geoql/mdr/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Vinayak Kulkarni",
    "email": "inbox.vinayak@gmail.com",
    "url": "https://vinayakkulkarni.dev"
  },
  "contributors": [
    "Matt Kane (https://github.com/ascorbic) — original author of ascorbic/macrodata"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geoql/mdr.git",
    "directory": "packages/macrodata"
  },
  "files": [
    "dist",
    "src",
    "opencode",
    "bin",
    "USAGE.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/opencode/index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "prepublishOnly": "pnpm build",
    "start": "node dist/src/index.js",
    "daemon": "node dist/bin/macrodata-daemon.js",
    "pretest": "pnpm build",
    "test": "vitest run",
    "check": "vp lint --type-aware --type-check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/plugin": "^1.17.18",
    "@opencode-ai/sdk": "^1.17.20",
    "chokidar": "^5.0.0",
    "croner": "^10.0.1",
    "vectra": "^0.15.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "oxfmt": "catalog:",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "latest",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "opencode": {
    "type": "plugin",
    "hooks": [
      "chat.message",
      "experimental.chat.system.transform",
      "experimental.session.compacting"
    ]
  }
}
