{
  "name": "@geoql/mdr-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @geoql/mdr — persistent layered memory for coding agents. A hard fork of ascorbic/macrodata by Matt Kane.",
  "homepage": "https://mdr.geoql.in",
  "bugs": {
    "url": "https://github.com/geoql/mdr/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Vinayak Kulkarni",
    "email": "inbox.vinayak@gmail.com",
    "url": "https://vinayakkulkarni.dev"
  },
  "contributors": [
    "Matt Kane (https://github.com/ascorbic) — original author of ascorbic/macrodata"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geoql/mdr.git"
  },
  "type": "module",
  "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578",
  "engines": {
    "node": ">=24.11.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.11.0"
    }
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build && pnpm --filter @geoql/mdr-marketing run build",
    "build:marketing": "pnpm --filter @geoql/mdr-marketing run build",
    "dev:marketing": "pnpm --filter @geoql/mdr-marketing dev",
    "lint": "pnpm -r --filter './packages/*' run lint",
    "lint:fix": "pnpm -r --filter './packages/*' run lint:fix",
    "format": "pnpm -r --filter './packages/*' run format",
    "format:check": "pnpm -r --filter './packages/*' run format:check",
    "typecheck": "pnpm -r --filter './packages/*' run check",
    "test": "vitest run",
    "coverage": "vitest run --coverage --testTimeout=90000",
    "prepare": "is-ci || husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^17.1.0",
    "vitest": "^4.1.10"
  }
}
