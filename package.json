{
	"name": "@geoql/mdr-monorepo",
	"version": "0.0.0",
	"private": true,
	"description": "Monorepo for @geoql/mdr — persistent layered memory for coding agents. A hard fork of ascorbic/macrodata by Matt Kane.",
	"homepage": "https://mdr.geoql.in",
	"bugs": {
		"url": "https://github.com/geoql/mdr/issues"
	},
	"license": "MIT",
	"author": {
		"name": "Vinayak Kulkarni",
		"email": "inbox.vinayak@gmail.com",
		"url": "https://vinayakkulkarni.dev"
	},
	"contributors": [
		"Matt Kane (https://github.com/ascorbic) — original author of ascorbic/macrodata"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/geoql/mdr.git"
	},
	"type": "module",
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
	"engines": {
		"node": ">=24.11.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=24.11.0"
		}
	},
	"scripts": {
		"build": "pnpm -r --filter './plugins/*' run build && pnpm --filter @geoql/mdr-marketing run build",
		"build:marketing": "pnpm --filter @geoql/mdr-marketing run build",
		"dev:marketing": "pnpm --filter @geoql/mdr-marketing dev",
		"lint": "pnpm -r --filter './plugins/*' run lint",
		"lint:fix": "pnpm -r --filter './plugins/*' run lint:fix",
		"format": "pnpm -r --filter './plugins/*' run format",
		"format:check": "pnpm -r --filter './plugins/*' run format:check",
		"typecheck": "pnpm -r --filter './plugins/*' run check",
		"test": "vitest run",
		"coverage": "vitest run --coverage --testTimeout=90000",
		"prepare": "is-ci || husky"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@vitest/coverage-v8": "^4.1.10",
		"husky": "^9.1.7",
		"is-ci": "^4.1.0",
		"lint-staged": "^17.0.8",
		"vitest": "^4.1.10"
	}
}
